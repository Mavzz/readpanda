# =============================================================================
# ReadPanda Admin Portal — Environment Variables
# Copy this file to .env.local and fill in your values.
# =============================================================================

# --- Backend ----------------------------------------------------------------
# IP or hostname of the Go backend (without http:// or trailing slash)
VITE_BACKEND_BASE_URL=localhost
VITE_BACKEND_PORT=3000
VITE_API_VERSION=/api/v1

# --- Crypto (must match CRYPTO_SECRET in the Go backend .env.local) ---------
VITE_CRYPTO_SECRET=change_me_crypto_secret

# --- Google OAuth ------------------------------------------------------------
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
